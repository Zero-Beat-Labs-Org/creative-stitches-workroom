---
import Base from '../layouts/Base.astro';
import { business } from '../data/business';

const title = 'Contact | Creative Stitches Workroom, Grand Blanc MI';
const description = 'Contact Creative Stitches Workroom in Grand Blanc, Michigan for custom draperies, Roman shades, window treatments, and upholstery. Call 810-423-3416.';

const addr = business.address;
// Static site form posts to Web3Forms (free). Set a real key to enable the form;
// until then the page shows a call-first block so nothing is broken at launch.
const WEB3FORMS_KEY = 'TODO-WEB3FORMS-ACCESS-KEY';
const formEnabled = !WEB3FORMS_KEY.startsWith('TODO');
---
<Base title={title} description={description}>
  <section>
    <div class="wrap">
      <h1>Get in touch</h1>
      <p class="lead">Tell us about your project and we will follow up to talk fabric, measurements, and timing.</p>

      <p>
        <strong>Phone:</strong> <a href={`tel:${business.phoneE164}`}>{business.phone}</a><br />
        {business.email && (<><strong>Email:</strong> <a href={`mailto:${business.email}`}>{business.email}</a><br /></>)}
        <strong>Workroom:</strong> {addr.street}, {addr.city}, {addr.region} {addr.postalCode}<br />
        <strong>Hours:</strong> {business.hours}
      </p>

      {formEnabled ? (
        <form action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="New inquiry from creativestitchesworkroom.com" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required />
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required />
          <label for="phone">Phone</label>
          <input id="phone" type="tel" name="phone" />
          <label for="message">What can we make for you?</label>
          <textarea id="message" name="message" rows="5" required></textarea>
          <p style="margin-top:1rem"><button class="btn" type="submit">Send</button></p>
        </form>
      ) : (
        <p><a class="btn" href={`tel:${business.phoneE164}`}>Call {business.phone}</a></p>
      )}
    </div>
  </section>
</Base>
