---
import Base from '../layouts/Base.astro';
import { business } from '../data/business';

const title = 'To the Trade | Creative Stitches Workroom for Interior Designers, Genesee County MI';
const description = 'A designer-friendly drapery and upholstery workroom for interior designers in Genesee County and mid-Michigan. Trade pricing, reliable lead times, white-label fabrication in your fabric.';
---
<Base title={title} description={description}>
  <section>
    <div class="wrap">
      <h1>To the trade</h1>
      <p class="lead">A dependable workroom partner for interior designers across Genesee County and mid-Michigan.</p>

      <h2>Why designers work with us</h2>
      <ul>
        <li>{business.yearsInBusiness} years of soft-goods fabrication: drapery, Roman shades, upholstery, cushions, bedding.</li>
        <li>Work in your materials. Send your own fabric and trim, and we fabricate to spec.</li>
        <li>White-label: we protect your client relationship.</li>
        <li>Trade pricing for qualified designers.</li>
      </ul>

      <h2>Start a trade account</h2>
      <p>
        <a class="btn" href={`tel:${business.phoneE164}`}>Call {business.phone}</a>
        <a class="btn btn-secondary" href="/contact/">Send project details</a>
      </p>
    </div>
  </section>
</Base>
