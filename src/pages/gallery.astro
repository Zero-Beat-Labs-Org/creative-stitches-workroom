---
import Base from '../layouts/Base.astro';
import { business } from '../data/business';
import { gallery } from '../data/gallery';

const title = 'Gallery | Creative Stitches Workroom, Grand Blanc MI';
const description = 'Project photos of custom draperies, Roman shades, upholstery, and window treatments handcrafted by Creative Stitches Workroom in Grand Blanc, Michigan.';

const houzz = business.sameAs.find((u) => u.includes('houzz'));
const facebook = business.sameAs.find((u) => u.includes('facebook'));
---
<Base title={title} description={description}>
  <section>
    <div class="wrap">
      <p class="eyebrow">Our work</p>
      <h1>Project gallery</h1>
      <p class="lead">A selection of recent custom drapery, Roman shades, upholstery, pillows, and window treatments, handcrafted in our Grand Blanc workroom.</p>

      <div class="gallery-masonry">
        {gallery.map((g, i) => (
          <img
            src={g.src}
            alt={g.alt}
            width={g.w}
            height={g.h}
            loading={i < 4 ? 'eager' : 'lazy'}
            fetchpriority={i < 4 ? 'high' : undefined}
            decoding="async"
          />
        ))}
      </div>

      <hr class="rule" style="margin-top:2.5rem" />
      <p>
        {houzz && <a class="btn btn-secondary" href={houzz}>More on Houzz</a>}
        {' '}
        {facebook && <a class="btn btn-secondary" href={facebook}>More on Facebook</a>}
      </p>
      <p>Have a project in mind? <a href={`tel:${business.phoneE164}`}>Call {business.phone}</a> or <a href="/contact/">send us the details</a>.</p>
    </div>
  </section>
</Base>
