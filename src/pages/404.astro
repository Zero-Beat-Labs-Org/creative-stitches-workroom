---
import Base from '../layouts/Base.astro';
const title = 'Page not found | Creative Stitches Workroom';
const description = 'That page could not be found.';
---
<Base title={title} description={description}>
  <section>
    <div class="wrap">
      <h1>Page not found</h1>
      <p class="lead">That page does not exist. Try the <a href="/">home page</a> or <a href="/services/">our services</a>.</p>
    </div>
  </section>
</Base>
